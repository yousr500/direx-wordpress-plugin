{
    "name": "jemaa/direx-plugin",
    "description": "A starter WordPress plugin for enhanced functionality.",
    "type": "project",
    "version": "1.0.0",
    "keywords": ["wordpress", "plugin", "starter", "php"],
    "homepage": "https://direx.com",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "Jemaa\\DirexPlugin\\":  "src/"

        }
    },
    "authors": [
        {
            "name": "Yosr"
        }
    ],
    "minimum-stability": "dev",
    "require":{ 
        "php": ">=7.4  || ^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.4",
        "monolog/monolog": "^3.0@dev"
    },
    "scripts": {
        "test": "phpunit",
        "post-install-cmd": [
            "@composer dump-autoload"
        ],
        "post-update-cmd": [
            "@composer dump-autoload"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "10"
    }
}
